                        "userId":{"type":"string", "example":"7"},
                        "nickname":{"type":"string", "example":"탱"},
                        "profileImage":{"type": "string", "nullable":true, "example":null},
                        "description":{"type":"string", "example":"."}
                      }
                    }
                  }

                }
              }
            }
          },
          "401":{
            "description": "인증 실패 - 토큰 누락 또는 만료",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "resultType": { "type": "string", "example": "FAIL" },
                    "error": {
                      "type": "object",
                      "properties": {
                        "errorCode": { "type": "string", "example": "AUTH001" },
                        "reason": { "type": "string", "example": "인증 정보가 없습니다." },
                        "data": { "type": ["object", "null"], "example": null }
                      }
                    },
                    "success": { "type": "null", "example": null }
                  }
                }
              }
            }
          }
        }
