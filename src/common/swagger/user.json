{
 "paths": {
    "/api/users": {
      "post": {
        "tags": ["User"],
        "summary": "회원가입",
        "description": "닉네임 입력까지 마친 후 호출 ",
        "requestBody": {
            "required" : true,
            "content" : {
                "application/json" : {
                    "schema" : {
                        "type" : "object",
                        "properties" : {
                            "nickname": { "type": "string", "example": "코지" },
                            "provider": { "type": "string", "example": "kakao" },
                            "oauth_id": { "type": "string", "example": "123456789" },
                            "categories": {
                                "type": "array",
                                "items": { "type": "integer" },
                                "example": [4, 5, 9]
                            },
                            "agreements": {
                                "type": "array",
                                "items": { "type": "integer" },
                                "example": [1, 2, 3]
                            }
                        }, 
                        "required": ["nickname", "provider", "oauth_id", "categories", "agreements"]
                    }
                }
            }
        },
        "responses": {
          "201": {
            "description": "회원가입 성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "resultType": { "type": "string", "example": "SUCCESS" },
                    "error": { "type": "null", "example": null },
                    "success": {
                      "type": "object",
                      "properties": {
                        "message": { "type": "string", "example": "회원가입이 성공적으로 완료되었습니다." },
                        "user":{
                            "userId": { "type": "integer", "example": 1 },
                            "nickname": { "type": "string", "example": "코지" },
                            "provider": { "type": "string", "example": "kakao" },
                            "oauth_id": { "type": "string", "example": "123456789" },
                            "created_at": {"type" : "string", "example": "2025-07-02T12:34:56Z"}
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "409": {
            "description": "이미 등록된 소셜 로그인 계정",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "resultType": { "type": "string", "example": "FAIL" },
                    "error": {
                      "type": "object",
                      "properties": {
                        "errorCode": { "type": "string", "example": "U001" },
                        "reason": { "type": "string", "example": "이미 등록된 소셜 로그인 계정입니다." },
                        "data": {
                          "type": "object",
                          "example": null
                        }
                      }
                    },
                    "success": { "type": "null", "example": null }
                  }
                }
              }
            }
          }
          
        }
      }
    }
  }
}
