{
 "paths": {
    "/api/users": {
      "post": {
        "tags": ["User"],
        "summary": "회원가입",
        "description": "소셜 로그인 후 가입되지 않은 사용자일 경우, 전달받은 JWT 토큰을 포함하여 사용자가 입력한 정보들을 DB에 등록합니다. (닉네임까지 입력 마친 후 호출)",
        "requestBody": {
            "required" : true,
            "content" : {
                "application/json" : {
                    "schema" : {
                        "type" : "object",
                        "properties" : {
                            "token": {"type": "string", "example" : "eyJhbGciOiJIUzI1NiIs..."},
                            "nickname": { "type": "string", "example": "코지" },
                            "categories": {
                                "type": "array",
                                "items": { "type": "integer" },
                                "example": [4, 5, 9]
                            },
                            "agreements": {
                                "type": "array",
                                "items": { "type": "integer" },
                                "example": [1, 2, 3]
                            }
                        }, 
                        "required": ["nickname", "token", "categories", "agreements"]
                    }
                }
            }
        },
        "responses": {
          "201": {
            "description": "회원가입 성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "resultType": { "type": "string", "example": "SUCCESS" },
                    "error": { "type": "null", "example": null },
                    "success": {
                      "type": "object",
                      "properties": {
                        "message": { "type": "string", "example": "회원가입이 성공적으로 완료되었습니다." },
                        "user":{
                            "type" : "object",
                            "properties" : {
                                "userId": { "type": "integer", "example": 1 },
                                "nickname": { "type": "string", "example": "코지" },
                                "provider": { "type": "string", "example": "kakao" },
                                "oauth_id": { "type": "string", "example": "123456789" },
                                "created_at": {"type" : "string", "example": "2025-07-02T12:34:56Z"}
                            }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "409": {
            "description": "만료 또는 유효하지 않은 토큰입니다.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "resultType": { "type": "string", "example": "FAIL" },
                    "error": {
                      "type": "object",
                      "properties": {
                        "errorCode": { "type": "string", "example": "U001" },
                        "reason": { "type": "string", "example": "만료 또는 유효하지 않은 토큰입니다." },
                        "data": {
                          "type": "object",
                          "example": null
                        }
                      }
                    },
                    "success": { "type": "null", "example": null }
                  }
                }
              }
            }
          }
          
        }
      }
    },
    "/api/users/oauth2/login/google" : {
      "get" :{
        "tags" :["User"],
        "summary" : "구글 소셜 로그인",
        "description" :"구글로 시작하기 버튼을 클릭하면, 이 API를 호출하여 구글 로그인 인증 url로 redirect됩니다.",
        "responses":{
          "302" : {
            "description": "구글 로그인 인증 페이지로 redirect 성공"
          },
          "500": {
            "description": "서버 내부 오류 발생"
          }
        }
      }
    },
    "/api/users/oauth2/login/kakao" : {
      "get" : {
        "tags":["User"],
        "summary" : "카카오 소셜 로그인",
        "description" :"카카오로 시작하기 버튼을 클릭하면, 이 API를 호출하여 카카오 로그인 인증 url로 redirect됩니다.",
        "responses": {
          "302": {
            "description" : "카카오 로그인 인증 페이지로 redirect 성공"
          },
          "500":{
            "description":"서버 내부 오류 발생"
          }
        }
      }
    },
    "/api/users/oauth2/login/naver" : {
      "get" : {
        "tags":["User"],
        "summary" : "네이버 소셜 로그인",
        "description" :"네이버로 시작하기 버튼을 클릭하면, 이 API를 호출하여 네이버 로그인 인증 url로 redirect됩니다.",
        "responses": {
          "302": {
            "description" : "네이버 로그인 인증 페이지로 redirect 성공"
          },
          "500":{
            "description":"서버 내부 오류 발생"
          }
        }
      }
    },
    "/api/users/oauth2/login/twitter" : {
      "get" : {
        "tags":["User"],
        "summary" : "트위터 소셜 로그인",
        "description" :"트위터로 시작하기 버튼을 클릭하면, 이 API를 호출하여 트위터 로그인 인증 url로 redirect됩니다.",
        "responses": {
          "302": {
            "description" : "트위터 로그인 인증 페이지로 redirect 성공"
          },
          "500":{
            "description":"서버 내부 오류 발생"
          }
        }
      }
    },
    "/api/users/me":{
      "get":{
        "tags":["User"],
        "summary": "나의 프로필 조회하기",
        "description": "마이페이지에서 프로필 버튼 클릭 시 호출하는 API",
        "security" : [
          {
            "bearerAuth":[]
          }
        ],
        "responses":{
          "200":{
            "description":"프로필 조회 성공",
            "content":{
              "application/json": {
                "schema":{
                  "type":"object",
                  "properties":{
                    "resultType":{"type":"object", "example":"SUCCESS"},
                    "error":{"type":null, "example":null},
                    "success":{
                      "type":"object",
                      "properties":{
                        "userId":{"type":"string", "example":"7"},
                        "nickname":{"type":"string", "example":"탱"},
                        "profileImage":{"type": ["string", null], "example":null},
                        "description":{"type":"string", "example":"."}
                      }
                    }
                  }

                }
              }
            }
          },
          "401":{
            "description": "인증 실패 - 토큰 누락 또는 만료",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "resultType": { "type": "string", "example": "FAIL" },
                    "error": {
                      "type": "object",
                      "properties": {
                        "errorCode": { "type": "string", "example": "AUTH001" },
                        "reason": { "type": "string", "example": "인증 정보가 없습니다." },
                        "data": { "type": ["object", "null"], "example": null }
                      }
                    },
                    "success": { "type": "null", "example": null }
                  }
                }
              }
            }
          }
        }
      },
      "patch":{
        "tags":["User"],
        "summary": "나의 프로필 수정하기",
        "description": "마이페이지에서 프로필 수정 버튼 클릭 시 호출하는 API입니다. 수정하고자 하는 내용만 request body로 넘겨주면 됩니다.",
        "security" : [
          {
            "bearerAuth":[]
          }
        ],
        "requestBody": {
            "required" : true,
            "content" : {
                "application/json" : {
                    "schema" : {
                        "type" : "object",
                        "properties" : {
                            "nickname":{"type":"string", "example":"탱"},
                            "profileImage":{"type": "string", "nullable":true, "example":null},
                            "description":{"type":"string", "example":"."}
                        }
                    }
                }
            }
        },
        "responses":{
          "200":{
            "description":"프로필 수정 성공",
            "content":{
              "application/json": {
                "schema":{
                  "type":"object",
                  "properties":{
                    "resultType":{"type":"object", "example":"SUCCESS"},
                    "error":{"type":null, "example":null},
                    "success":{
                      "type":"object",
                      "properties":{
                        "userId":{"type":"string", "example":"7"},
                        "nickname":{"type":"string", "example":"탱"},
                        "profileImage":{"type": "string", "nullable":true, "example":null},
                        "description":{"type":"string", "example":"."}
                      }
                    }
                  }

                }
              }
            }
          },
          "401":{
            "description": "인증 실패 - 토큰 누락 또는 만료",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "resultType": { "type": "string", "example": "FAIL" },
                    "error": {
                      "type": "object",
                      "properties": {
                        "errorCode": { "type": "string", "example": "AUTH001" },
                        "reason": { "type": "string", "example": "인증 정보가 없습니다." },
                        "data": { "type": ["object", "null"], "example": null }
                      }
                    },
                    "success": { "type": "null", "example": null }
                  }
                }
              }
            }
          }
        }
      }
    }
    
    
  }
}
