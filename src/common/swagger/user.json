{
 "paths": {
    "/api/users": {
      "post": {
        "tags": ["User"],
        "summary": "회원가입",
        "description": "소셜 로그인 후 가입되지 않은 사용자일 경우, 전달받은 JWT 토큰을 포함하여 사용자가 입력한 정보들을 DB에 등록합니다. (닉네임까지 입력 마친 후 호출) , 작가인 경우 role='artist', 신청자일 경우 role='client'",
        "requestBody": {
            "required" : true,
            "content" : {
                "application/json" : {
                    "schema" : {
                        "type" : "object",
                        "properties" : {
                            "token": {"type": "string", "example" : "eyJhbGciOiJIUzI1NiIs..."},
                            "nickname": { "type": "string", "example": "코지" },
                            "role":{"type":"string", "example":"artist"},
                            "categories": {
                                "type": "array",
                                "items": { "type": "integer" },
                                "example": [4, 5, 9]
                            },
                            "agreements": {
                                "type": "array",
                                "items": { "type": "integer" },
                                "example": [1, 2, 3]
                            }
                        }, 
                        "required": ["nickname", "token", "categories", "agreements"]
                    }
                }
            }
        },
        "responses": {
          "201": {
            "description": "회원가입 성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "resultType": { "type": "string", "example": "SUCCESS" },
                    "error": { "type": "null", "example": null },
                    "success": {
                      "type": "object",
                      "properties": {
                        "message": { "type": "string", "example": "회원가입이 성공적으로 완료되었습니다." },
                        "user":{
                            "type" : "object",
                            "properties" : {
                                "userId": { "type": "integer", "example": 1 },
                                "nickname": { "type": "string", "example": "코지" },
                                "provider": { "type": "string", "example": "kakao" },
                                "oauth_id": { "type": "string", "example": "123456789" },
                                "created_at": {"type" : "string", "example": "2025-07-02T12:34:56Z"}
                            }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "409": {
            "description": "만료 또는 유효하지 않은 토큰입니다.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "resultType": { "type": "string", "example": "FAIL" },
                    "error": {
                      "type": "object",
                      "properties": {
                        "errorCode": { "type": "string", "example": "U001" },
                        "reason": { "type": "string", "example": "만료 또는 유효하지 않은 토큰입니다." },
                        "data": {
                          "type": "object",
                          "example": null
                        }
                      }
                    },
                    "success": { "type": "null", "example": null }
                  }
                }
              }
            }
          }
          
        }
      }
    },
