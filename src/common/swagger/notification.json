{
    "paths": {
        "/api/notifications": {
            "get": {
                "tags": [
                    "Notification"
                ],
                "summary": "알림 목록 조회",
                "description": "사용자의 알림 목록을 조회합니다.",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "page",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "minimum": 1,
                            "default": 1
                        },
                        "description": "페이지 번호 (기본값: 1)"
                    },
                    {
                        "name": "limit",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "minimum": 1,
                            "maximum": 50,
                            "default": 20
                        },
                        "description": "페이지당 항목 수 (기본값: 20, 최대: 50)"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "알림 목록 조회 성공",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/NotificationListResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "인증 실패",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "사용자를 찾을 수 없음",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "서버 오류",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/notifications/{notificationId}/read": {
            "patch": {
                "tags": [
                    "Notification"
                ],
                "summary": "개별 알림 읽음 처리",
                "description": "특정 알림을 읽음 상태로 변경합니다.",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "notificationId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        },
                        "description": "알림 ID"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "알림 읽음 처리 성공",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/NotificationReadResponse"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "이미 읽은 알림",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "인증 실패",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    },
                    "403": {
                        "description": "알림에 접근 권한이 없음",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "알림을 찾을 수 없음",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/notifications/read-all": {
            "patch": {
                "tags": [
                    "Notification"
                ],
                "summary": "모든 알림 읽음 처리",
                "description": "사용자가 읽지 않은 알림들을 모두 읽음 상태로 변경합니다.",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "모든 알림 읽음 처리 성공",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/BulkUpdateResponse"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "읽지 않은 알림이 없음",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "인증 실패",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "사용자를 찾을 수 없음",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/notifications/bulk": {
            "delete": {
                "tags": [
                    "Notification"
                ],
                "summary": "선택 알림 삭제",
                "description": "선택한 알림들을 삭제합니다.",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/BulkDeleteRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "선택 알림 삭제 성공",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/BulkDeleteResponse"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "삭제할 알림을 선택하지 않았거나 삭제할 알림이 없음",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "인증 실패",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "사용자를 찾을 수 없음",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/notifications/all": {
            "delete": {
                "tags": [
                    "Notification"
                ],
                "summary": "전체 알림 삭제",
                "description": "사용자의 모든 알림을 삭제합니다.",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "전체 알림 삭제 성공",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/BulkDeleteResponse"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "삭제할 알림이 없음",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "인증 실패",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "사용자를 찾을 수 없음",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/notifications/fcm/token": {
            "post": {
                "tags": ["Notification"],
                "summary": "FCM 토큰 등록",
                "description": "사용자의 FCM 토큰을 서버에 등록합니다. 등록된 토큰은 이후 Push 알림 발송 시 사용됩니다.",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/FCMTokenRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "FCM 토큰 등록 성공",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/FCMTokenResponse"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "유효하지 않은 FCM 토큰",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                },
                                "example": {
                                    "resultType": "FAIL",
                                    "error": {
                                        "errorCode": "N009",
                                        "reason": "FCM 토큰이 비어있거나 유효하지 않습니다",
                                        "data": {
                                            "fcm_token": "invalid_token"
                                        }
                                    },
                                    "success": null
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "인증 실패",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "사용자를 찾을 수 없음",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    }
                }
            },
            "delete": {
                "tags": ["Notification"],
                "summary": "FCM 토큰 삭제",
                "description": "사용자의 FCM 토큰을 서버에서 삭제합니다. 삭제 후에는 해당 사용자에게 FCM Push 알림이 발송되지 않습니다.",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "FCM 토큰 삭제 성공",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/FCMTokenDeleteResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "인증 실패",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "등록된 FCM 토큰을 찾을 수 없음",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                },
                                "example": {
                                    "resultType": "FAIL",
                                    "error": {
                                        "errorCode": "N008",
                                        "reason": "등록된 FCM 토큰이 없습니다",
                                        "data": {
                                            "userId": "999"
                                        }
                                    },
                                    "success": null
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "NotificationListResponse": {
                "type": "object",
                "properties": {
                    "resultType": {
                        "type": "string",
                        "example": "SUCCESS"
                    },
                    "error": {
                        "type": "null"
                    },
                    "success": {
                        "type": "object",
                        "properties": {
                            "items": {
                                "type": "array",
                                "items": {
                                    "$ref": "#/components/schemas/NotificationItem"
                                },
                                "description": "알림 목록"
                            },
                            "pagination": {
                                "$ref": "#/components/schemas/Pagination"
                            }
                        }
                    }
                }
            },
            "NotificationItem": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string",
                        "description": "알림 ID",
                        "example": "10"
                    },
                    "user_id": {
                        "type": "string",
                        "description": "사용자 ID",
                        "example": "999"
                    },
                    "title": {
                        "type": "string",
                        "description": "알림 제목",
                        "example": "결제 요청이 도착했어요"
                    },
                    "content": {
                        "type": "string",
                        "description": "알림 내용",
                        "example": "키르님이 40000 포인트 결제 요청을 보냈어요."
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "description": "생성 시간 (KST)",
                        "example": "2025-07-20T19:27:05.956+09:00"
                    },
                    "is_read": {
                        "type": "boolean",
                        "description": "읽음 여부",
                        "example": false
                    },
                    "type": {
                        "$ref": "#/components/schemas/NotificationType"
                    },
                    "related_data": {
                        "type": "object",
                        "description": "관련 데이터 (알림 타입별로 다름)",
                        "example": {
                            "requestId": "456",
                            "amount": 40000,
                            "creatorName": "키르",
                            "commissionTitle": "낙서 타입 커미션"
                        }
                    }
                }
            },
            "NotificationType": {
                "type": "string",
                "enum": [
                    "commission_submitted",
                    "commission_approved",
                    "commission_rejected",
                    "payment_request",
                    "work_started",
                    "work_completed"
                ],
                "description": "알림 타입"
            },
            "NotificationReadResponse": {
                "type": "object",
                "properties": {
                    "resultType": {
                        "type": "string",
                        "example": "SUCCESS"
                    },
                    "error": {
                        "type": "null"
                    },
                    "success": {
                        "type": "object",
                        "properties": {
                            "id": {
                                "type": "string",
                                "description": "알림 ID",
                                "example": "10"
                            },
                            "is_read": {
                                "type": "boolean",
                                "description": "읽음 상태",
                                "example": true
                            },
                            "read_at": {
                                "type": "string",
                                "format": "date-time",
                                "description": "읽음 처리 시간 (KST)",
                                "example": "2025-07-20T19:30:00.000+09:00"
                            }
                        }
                    }
                }
            },
            "BulkUpdateResponse": {
                "type": "object",
                "properties": {
                    "resultType": {
                        "type": "string",
                        "example": "SUCCESS"
                    },
                    "error": {
                        "type": "null"
                    },
                    "success": {
                        "type": "object",
                        "properties": {
                            "updated_count": {
                                "type": "integer",
                                "description": "읽음 처리된 알림 개수",
                                "example": 5
                            }
                        }
                    }
                }
            },
            "BulkDeleteRequest": {
                "type": "object",
                "required": [
                    "notification_ids"
                ],
                "properties": {
                    "notification_ids": {
                        "type": "array",
                        "items": {
                            "type": "integer"
                        },
                        "description": "삭제할 알림 ID 배열",
                        "example": [
                            10,
                            11,
                            13
                        ]
                    }
                }
            },
            "BulkDeleteResponse": {
                "type": "object",
                "properties": {
                    "resultType": {
                        "type": "string",
                        "example": "SUCCESS"
                    },
                    "error": {
                        "type": "null"
                    },
                    "success": {
                        "type": "object",
                        "properties": {
                            "deleted_count": {
                                "type": "integer",
                                "description": "삭제된 알림 개수",
                                "example": 3
                            },
                            "message": {
                                "type": "string",
                                "description": "성공 메시지",
                                "example": "선택한 알림이 성공적으로 삭제되었습니다."
                            }
                        }
                    }
                }
            },
            "ErrorResponse": {
                "type": "object",
                "properties": {
                    "resultType": {
                        "type": "string",
                        "example": "FAIL"
                    },
                    "error": {
                        "type": "object",
                        "properties": {
                            "errorCode": {
                                "type": "string",
                                "description": "에러 코드 (N001-N007)",
                                "example": "N001"
                            },
                            "reason": {
                                "type": "string",
                                "description": "에러 메시지",
                                "example": "알림을 찾을 수 없습니다"
                            },
                            "data": {
                                "type": "object",
                                "description": "에러 관련 추가 데이터",
                                "example": {
                                    "notificationId": "999"
                                }
                            }
                        }
                    },
                    "success": {
                        "type": "null"
                    }
                }
            },
            "Pagination": {
                "type": "object",
                "properties": {
                    "page": {
                        "type": "integer",
                        "description": "현재 페이지",
                        "example": 1
                    },
                    "limit": {
                        "type": "integer",
                        "description": "페이지당 항목 수",
                        "example": 20
                    },
                    "total": {
                        "type": "integer",
                        "description": "전체 항목 수",
                        "example": 45
                    },
                    "totalPages": {
                        "type": "integer",
                        "description": "전체 페이지 수",
                        "example": 3
                    }
                }
            },
            "FCMTokenRequest": {
                "type": "object",
                "required": ["fcm_token"],
                "properties": {
                    "fcm_token": {
                        "type": "string",
                        "description": "Firebase에서 발급받은 FCM 등록 토큰",
                        "example": "eUEgH26SRvyQXjA95fW7E-:APA91bEBBsIhHEo7z0iVzFHpQT-gnR5IGHU27w6ROMyIgZ0MO3ihZE3z6JY8_OwV3Bef3bC19MOdnACIEJ8KjsZ44NG_sruDF6y2suaxVRp4DBqI3gg96Tw"
                    }
                }
            },
            "FCMTokenResponse": {
                "type": "object",
                "properties": {
                    "resultType": {
                        "type": "string",
                        "example": "SUCCESS"
                    },
                    "error": {
                        "type": "null"
                    },
                    "success": {
                        "type": "object",
                        "properties": {
                            "id": {
                                "type": "string",
                                "description": "FCM 토큰 DB ID",
                                "example": "1"
                            },
                            "user_id": {
                                "type": "string",
                                "description": "사용자 ID",
                                "example": "999"
                            },
                            "fcm_token": {
                                "type": "string",
                                "description": "등록된 FCM 토큰",
                                "example": "eUEgH26SRvyQXjA95fW7E-:APA91bE..."
                            },
                            "is_active": {
                                "type": "boolean",
                                "description": "토큰 활성화 상태",
                                "example": true
                            },
                            "created_at": {
                                "type": "string",
                                "format": "date-time",
                                "description": "생성 시간 (KST)",
                                "example": "2025-07-27T18:30:00.000+09:00"
                            },
                            "updated_at": {
                                "type": "string",
                                "format": "date-time",
                                "description": "수정 시간 (KST)",
                                "example": "2025-07-27T18:30:00.000+09:00"
                            }
                        }
                    }
                }
            },
            "FCMTokenDeleteResponse": {
                "type": "object",
                "properties": {
                    "resultType": {
                        "type": "string",
                        "example": "SUCCESS"
                    },
                    "error": {
                        "type": "null"
                    },
                    "success": {
                        "type": "object",
                        "properties": {
                            "message": {
                                "type": "string",
                                "example": "FCM 토큰이 성공적으로 삭제되었습니다."
                            }
                        }
                    }
                }
            }
        }
    }
}