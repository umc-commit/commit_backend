{
  "paths": {
    "/api/search": {
      "get": {
        "tags": ["Search"],
        "summary": "검색 결과 조회",
        "description": "키워드, 필터, 정렬 조건에 따른 검색 결과를 반환합니다.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "keyword",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "example": "키워드"
            },
            "description": "검색어 (일반: '키워드', 작가: '@작가명', 태그: '#태그명1 #태그명2')"
          },
          {
            "name": "categoryId",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "nullable": true,
              "example": null
            },
            "description": "카테고리 ID"
          },
          {
            "name": "sort",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["latest", "price_low", "price_high"],
              "example": "latest"
            },
            "description": "정렬 방식 (기본값: latest)"
          },
          {
            "name": "minPrice",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "nullable": true,
              "example": null
            },
            "description": "최소 가격"
          },
          {
            "name": "maxPrice",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "nullable": true,
              "example": null
            },
            "description": "최대 가격"
          },
          {
            "name": "deadline",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["all", "1", "7", "14", "30"],
              "example": "all"
            },
            "description": "마감 기한 (기본값: all)"
          },
          {
            "name": "followingOnly",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "example": false
            },
            "description": "팔로잉 작가만 조회 (기본값: false)"
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "example": 1
            },
            "description": "페이지 번호 (기본값: 1)"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "example": 12
            },
            "description": "페이지당 결과 수 (기본값: 12, 최대: 50)"
          }
        ],
        "responses": {
          "200": {
            "description": "검색 성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "resultType": { "type": "string", "example": "SUCCESS" },
                    "error": { "type": "null", "example": null },
                    "success": {
                      "type": "object",
                      "properties": {
                        "commissions": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": { "type": "integer", "example": 1 },
                              "title": { "type": "string", "example": "커미션 제목" },
                              "minPrice": { "type": "integer", "example": 50000 },
                              "thumbnailImageUrl": { "type": "string", "nullable": true, "example": "https://example.com/thumbnail1.jpg" },
                              "deadline": { "type": "integer", "nullable": true, "example": 21 },
                              "isBookmarked": { "type": "boolean", "example": true },
                              "category": {
                                "type": "object",
                                "properties": {
                                  "id": { "type": "integer", "example": 1 },
                                  "name": { "type": "string", "example": "글" }
                                }
                              },
                              "artist": {
                                "type": "object",
                                "properties": {
                                  "id": { "type": "integer", "example": 1 },
                                  "nickname": { "type": "string", "example": "위시" },
                                  "profileImageUrl": { "type": "string", "nullable": true, "example": "https://example.com/profile1.jpg" }
                                }
                              },
                              "tags": {
                                "type": "array",
                                "items": {
                                  "type": "object",
                                  "properties": {
                                    "id": { "type": "integer", "example": 1 },
                                    "name": { "type": "string", "example": "캐릭터" }
                                  }
                                }
                              }
                            }
                          }
                        },
                        "pagination": {
                          "type": "object",
                          "properties": {
                            "page": { "type": "integer", "example": 1 },
                            "limit": { "type": "integer", "example": 12 },
                            "totalCount": { "type": "integer", "example": 24 },
                            "totalPages": { "type": "integer", "example": 2 }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "잘못된 요청",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "resultType": { "type": "string", "example": "FAIL" },
                    "error": {
                      "type": "object",
                      "properties": {
                        "errorCode": { "type": "string", "example": "S001" },
                        "reason": { "type": "string", "example": "검색어는 1글자 이상이어야 합니다." },
                        "data": { "type": "null", "example": null }
                      }
                    },
                    "success": { "type": "null", "example": null }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/search/tags": {
      "get": {
        "tags": ["Search"],
        "summary": "추천 태그 조회",
        "description": "검색창 상단에서 보여줄 추천 태그들을 랜덤으로 반환합니다.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "example": 6
            },
            "description": "조회할 태그 개수 (기본값: 6)"
          }
        ],
        "responses": {
          "200": {
            "description": "추천 태그 조회 성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "resultType": { "type": "string", "example": "SUCCESS" },
                    "error": { "type": "null", "example": null },
                    "success": {
                      "type": "object",
                      "properties": {
                        "tags": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": { "type": "integer", "example": 1 },
                              "name": { "type": "string", "example": "일러스트" }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}