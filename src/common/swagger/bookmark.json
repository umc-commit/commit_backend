{
 "paths": {
    "/api/commissions/{commissionId}/bookmarks": {
      "post": {
        "tags": ["Bookmark"],
        "summary": "북마크 추가",
        "description": "메인, 검색, 상세에서 북마크 아이콘 클릭 시 호출",
        "parameters": [
          {
            "name": "commissionId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int64" }
          },
          {
            "name": "userId",
            "in": "header",
            "required": true,
            "schema": { "type": "integer", "format": "int64" }
          }
        ],
        "responses": {
          "201": {
            "description": "북마크 추가 성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "resultType": { "type": "string", "example": "SUCCESS" },
                    "error": { "type": "null", "example": null },
                    "success": {
                      "type": "object",
                      "properties": {
                        "bookmarkId": { "type": "integer", "example": 1 },
                        "commissionId": { "type": "integer", "example": 12 },
                        "message": { "type": "string", "example": "북마크가 추가되었습니다." }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "이미 북마크된 커미션",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "resultType": { "type": "string", "example": "FAIL" },
                    "error": {
                      "type": "object",
                      "properties": {
                        "errorCode": { "type": "string", "example": "B002" },
                        "reason": { "type": "string", "example": "이미 북마크된 커미션입니다." },
                        "data": {
                          "type": "object",
                          "properties": {
                            "userId": { "type": "integer", "example": 1 },
                            "commissionId": { "type": "integer", "example": 12 },
                            "bookmarkId": { "type": "integer", "example": 5 }
                          }
                        }
                      }
                    },
                    "success": { "type": "null", "example": null }
                  }
                }
              }
            }
          },
          "404": {
            "description": "존재하지 않는 커미션",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "resultType": { "type": "string", "example": "FAIL" },
                    "error": {
                      "type": "object",
                      "properties": {
                        "errorCode": { "type": "string", "example": "B001" },
                        "reason": { "type": "string", "example": "존재하지 않는 커미션입니다." },
                        "data": {
                          "type": "object",
                          "properties": {
                            "commissionId": { "type": "integer", "example": 12 }
                          }
                        }
                      }
                    },
                    "success": { "type": "null", "example": null }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/commissions/{commissionId}/bookmarks/{bookmarkId}": {
      "delete": {
        "tags": ["Bookmark"],
        "summary": "북마크 삭제",
        "description": "메인, 검색, 상세에서 북마크 아이콘 클릭 시 호출",
        "parameters": [
          {
            "name": "commissionId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          },
          {
            "name": "bookmarkId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          },
          {
            "name": "userId",
            "in": "header",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "북마크 삭제 성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "resultType": { "type": "string", "example": "SUCCESS" },
                    "error": { "type": "null", "example": null },
                    "success": {
                      "type": "object",
                      "properties": {
                        "bookmarkId": { "type": "integer", "example": 1 },
                        "commissionId": { "type": "integer", "example": 12 },
                        "message": { "type": "string", "example": "북마크가 삭제되었습니다." }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/bookmarks": {
      "delete": {
        "tags": ["Bookmark"],
        "summary": "북마크 선택 삭제",
        "description": "마이페이지에서 북마크를 선택 삭제",
        "parameters": [
          {
            "name": "userId",
            "in": "header",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "bookmarkIds": {
                    "type": "array",
                    "items": { "type": "integer" },
                    "example": [1, 2, 3]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "선택한 북마크 삭제 결과",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "resultType": { "type": "string", "example": "SUCCESS" },
                    "error": { "type": "null", "example": null },
                    "success": {
                      "type": "object",
                      "properties": {
                        "deletedIds": {
                          "type": "array",
                          "items": { "type": "integer" },
                          "example": [1, 2]
                        },
                        "notFoundIds": {
                          "type": "array",
                          "items": { "type": "integer" },
                          "example": [3]
                        },
                        "message": {
                          "type": "string",
                          "example": "선택한 북마크가 삭제되었습니다."
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "207": {
            "description": "일부 북마크만 삭제됨"
          }
        }
      }
    }
  }
}
