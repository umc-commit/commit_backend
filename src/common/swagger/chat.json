{
  "paths": {
    "/api/chatrooms": {
      "post": {
        "summary": "채팅방 생성",
        "description": "consumerId, artistId, requestId로 채팅방을 생성합니다.",
        "tags": ["Chat"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "consumerId": { "type": "integer", "example": 1 },
                  "artistId": { "type": "integer", "example": 2 },
                  "requestId": { "type": "integer", "example": 3 }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "생성된 채팅방 정보 반환",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "resultType": { "type": "string", "example": "SUCCESS" },
                    "error": { "type": "object", "nullable": true },
                    "success": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "integer", "example": 10 },
                        "consumerId": { "type": "integer", "example": 1 },
                        "artistId": { "type": "integer", "example": 2 },
                        "requestId": { "type": "integer", "example": 3 }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "사용자, 작가, 요청 중 하나를 찾을 수 없음"
          }
        }
      }
    },
    "/api/chatrooms/{consumerId}": {
      "get": {
        "summary": "사용자 ID로 채팅방 목록 조회",
        "description": "사용자 ID를 바탕으로 해당 사용자가 참여한 채팅방 목록을 조회합니다.",
        "tags": ["Chat"],
        "parameters": [
          {
            "name": "consumerId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "example": "1"
            },
            "description": "조회할 사용자의 ID"
          }
        ],
        "responses": {
          "200": {
            "description": "채팅방 목록 조회 성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "resultType": {
                      "type": "string",
                      "example": "SUCCESS"
                    },
                    "error": {
                      "type": "object",
                      "nullable": true,
                      "example": null
                    },
                    "success": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": { "type": "integer", "example": 10 },
                          "consumerId": { "type": "integer", "example": 1 },
                          "artistId": { "type": "integer", "example": 2 },
                          "requestId": { "type": "integer", "example": 3 },
                          "createdAt": { "type": "string", "format": "date-time" },
                          "updatedAt": { "type": "string", "format": "date-time" }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "사용자를 찾을 수 없음",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "resultType": { "type": "string", "example": "FAIL" },
                    "error": {
                      "type": "object",
                      "properties": {
                        "errorCode": { "type": "string", "example": "U001" },
                        "reason": { "type": "string", "example": "사용자 id를 찾을 수 없습니다." },
                        "data": { "type": "object" }
                      }
                    },
                    "success": { "type": "object", "nullable": true, "example": null }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/chatrooms/delete": {
      "delete": {
        "summary": "채팅방 소프트 삭제 (hidden 처리) 및 조건부 하드 삭제",
        "description": "사용자가 선택한 채팅방들을 hidden 처리 후, hiddenUser와 hiddenArtist가 모두 true인 경우 DB에서 삭제합니다.",
        "tags": ["Chat"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "chatroomIds": {
                    "type": "array",
                    "items": {
                      "type": "integer",
                      "example": 10
                    }
                  },
                  "userType": {
                    "type": "string",
                    "enum": ["consumer", "artist"],
                    "example": "consumer"
                  }
                },
                "required": ["chatroomIds", "userType"]
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "삭제 처리 완료 (내용 없음)"
          },
          "400": {
            "description": "잘못된 요청 파라미터"
          },
          "404": {
            "description": "채팅방을 찾을 수 없음"
          }
        }
      }
    }
  }
}