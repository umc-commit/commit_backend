{
  "paths": {
    "/api/points/current": {
      "get": {
        "tags": ["Points"],
        "summary": "사용자 현재 포인트 조회",
        "description": "사용자의 현재 포인트를 조회합니다.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "사용자 현재 포인트 조회 성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "$ref": "#/components/schemas/Point"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "JWT 인증 실패",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "서버 오류",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/points/products": {
      "get": {
        "tags": ["Points"],
        "summary": "상품 목록 조회",
        "description": "등록된 상품 목록을 조회합니다.",
        "responses": {
          "200": {
            "description": "성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Product"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/points/transactions": {
      "get": {
        "tags": ["Points"],
        "summary": "포인트 거래 내역 조회",
        "description": "사용자의 포인트 거래 내역을 조회합니다. 선택적으로 requestId를 쿼리로 넘겨 특정 요청의 거래 내역만 조회할 수 있습니다.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "requestId",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "example": "123"
            },
            "description": "조회할 커미션 요청 ID (선택)"
          }
        ],
        "responses": {
          "200": {
            "description": "거래 내역 조회 성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/TransactionHistoryItem"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "JWT 인증 실패",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "서버 오류",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/points/transfer": {
      "post": {
        "tags": ["Points"],
        "summary": "포인트 사용 (거래)",
        "description": "사용자가 특정 요청(request)에 대해 포인트를 사용합니다. 현재 포인트가 부족하면 에러를 반환합니다.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TransferPointRequest"
              },
              "example": {
                "requestId": 123,
                "amount": 500
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "포인트 사용 성공",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransferPointResponse"
                },
                "example": {
                  "resultType": "SUCCESS",
                  "success": {
                    "updatedPoint": {
                      "id": 1,
                      "userId": 1,
                      "amount": 1500,
                      "createdAt": "2025-07-23T10:00:00.000Z",
                      "updatedAt": "2025-07-23T10:05:00.000Z"
                    },
                    "pointTransaction": {
                      "id": 10,
                      "userId": 1,
                      "requestId": 123,
                      "paymentId": null,
                      "status": "USED",
                      "amount": -500,
                      "balance": 1500,
                      "createdAt": "2025-07-23T10:05:00.000Z"
                    }
                  },
                  "error": null
                }
              }
            }
          },
          "400": {
            "description": "잔액 부족 / 중복 결제 / 유효하지 않은 요청",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "InsufficientPointError": {
                    "summary": "포인트 부족",
                    "value": {
                      "resultType": "FAIL",
                      "error": {
                        "errorCode": "InsufficientPointError",
                        "reason": "잔액이 부족합니다.",
                        "data": null
                      },
                      "success": null
                    }
                  },
                  "DuplicatePaymentError": {
                    "summary": "중복 결제",
                    "value": {
                      "resultType": "FAIL",
                      "error": {
                        "errorCode": "P003",
                        "reason": "중복된 거래입니다.",
                        "data": {
                          "requestId": 123
                        }
                      },
                      "success": null
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "JWT 인증 실패",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "resultType": "FAIL",
                  "error": {
                    "errorCode": "UnauthorizedError",
                    "reason": "로그인이 필요합니다.",
                    "data": null
                  },
                  "success": null
                }
              }
            }
          },
          "500": {
            "description": "서버 오류",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "resultType": "FAIL",
                  "error": {
                    "errorCode": "unknown",
                    "reason": "Internal Server Error",
                    "data": null
                  },
                  "success": null
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Point": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "1"
          },
          "userId": {
            "type": "string",
            "example": "1"
          },
          "amount": {
            "type": "integer",
            "example": 3000
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2025-07-21T09:30:00.000Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "example": "2025-07-21T09:30:00.000Z"
          }
        }
      },
      "Product": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "1"
          },
          "point": {
            "type": "integer",
            "example": 1000
          },
          "price": {
            "type": "integer",
            "example": 1200
          }
        }
      },
      "TransferPointRequest": {
        "type": "object",
        "properties": {
          "requestId": {
            "type": "integer",
            "description": "커미션 요청 ID"
          },
          "amount": {
            "type": "integer",
            "description": "사용할 포인트 금액"
          }
        },
        "required": ["requestId", "amount"]
      },
      "TransferPointResponse": {
        "type": "object",
        "properties": {
          "resultType": {
            "type": "string",
            "example": "SUCCESS"
          },
          "success": {
            "type": "object",
            "properties": {
              "updatedPoint": {
                "$ref": "#/components/schemas/Point"
              },
              "pointTransaction": {
                "$ref": "#/components/schemas/PointTransaction"
              }
            }
          },
          "error": {
            "type": ["object", "null"]
          }
        }
      },
      "PointTransaction": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "userId": { "type": "integer" },
          "requestId": { "type": ["integer", "null"] },
          "paymentId": { "type": ["integer", "null"] },
          "status": { "type": "string" },
          "amount": { "type": "integer" },
          "balance": { "type": "integer" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "TransactionHistoryItem": {
        "type": "object",
        "properties": {
          "time": {
            "type": "string",
            "format": "date-time",
            "example": "2025-07-26T12:34:56.000Z"
          },
          "baseAmount": {
            "type": "integer",
            "description": "기본 금액 (Commission.minPrice)",
            "example": 1000
          },
          "extraAmount": {
            "type": "integer",
            "description": "추가 금액 (amount - base)",
            "example": 500
          },
          "totalAmount": {
            "type": "integer",
            "description": "총 결제 금액 (Request.totalPrice)",
            "example": 1500
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "resultType": {
            "type": "string",
            "example": "FAIL"
          },
          "error": {
            "type": "object",
            "properties": {
              "errorCode": { "type": "string" },
              "reason": { "type": "string" },
              "data": { "type": ["object", "null"] }
            }
          },
          "success": {
            "type": ["object", "null"]
          }
        }
      }
    }
  }
}