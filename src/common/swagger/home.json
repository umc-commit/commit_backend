{
  "paths": {
    "/api/home": {
      "get": {
        "tags": ["Home"],
        "summary": "홈화면 데이터 조회",
        "description": "홈화면에 표시될 6개 섹션의 데이터를 한 번에 조회합니다. (추천 커미션, 신규등록, 신청폭주, 마감임박, 최신 후기, 신규 작가)",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "홈화면 데이터 조회 성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "resultType": { "type": "string", "example": "SUCCESS" },
                    "error": { "type": "null", "example": null },
                    "success": {
                      "type": "object",
                      "properties": {
                        "section1": {
                          "type": "array",
                          "description": "추천 커미션",
                          "items": {
                            "$ref": "#/components/schemas/CommissionItem"
                          }
                        },
                        "section2": {
                          "type": "array", 
                          "description": "신규등록",
                          "items": {
                            "$ref": "#/components/schemas/CommissionItem"
                          }
                        },
                        "section3": {
                          "type": "array",
                          "description": "신청폭주", 
                          "items": {
                            "$ref": "#/components/schemas/CommissionItem"
                          }
                        },
                        "section4": {
                          "type": "array",
                          "description": "마감임박",
                          "items": {
                            "$ref": "#/components/schemas/CommissionItem"
                          }
                        },
                        "newReview": {
                          "type": "array",
                          "description": "최신 후기",
                          "items": {
                            "$ref": "#/components/schemas/ReviewItem"
                          }
                        },
                        "newArtist": {
                          "type": "array",
                          "description": "신규 작가",
                          "items": {
                            "$ref": "#/components/schemas/ArtistItem"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CommissionItem": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "title": { "type": "string", "example": "커미션 제목" },
          "category": { "type": "string", "example": "그림" },
          "tags": {
            "type": "array",
            "items": { "type": "string" },
            "example": ["LD", "커플"]
          },
          "thumbnailImageUrl": {
            "type": "string",
            "nullable": true,
            "example": "https://example.com/image.jpg"
          },
          "isBookmarked": { "type": "boolean", "example": false },
          "artist": {
            "type": "object",
            "properties": {
              "id": { "type": "integer", "example": 12 },
              "nickname": { "type": "string", "example": "작가닉네임" },
              "profileImageUrl": {
                "type": "string",
                "nullable": true,
                "example": "https://example.com/profile.jpg"
              }
            }
          }
        }
      },
      "ReviewItem": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 6 },
          "rate": { "type": "integer", "minimum": 1.0, "maximum": 5.0, "example": 3.0 },
          "content": { "type": "string", "example": "리뷰내용" },
          "duration": {
            "type": "string",
            "nullable": true,
            "example": "3일",
            "description": "작업기간"
          },
          "reviewImageUrl": {
            "type": "string",
            "nullable": true,
            "example": "https://example.com/review.jpg"
          },
          "user": {
            "type": "object",
            "properties": {
              "id": { "type": "integer", "example": 12 },
              "nickname": { "type": "string", "example": "유저닉네임" },
              "profileImageUrl": {
                "type": "string",
                "nullable": true,
                "example": "https://example.com/profile.jpg"
              }
            }
          },
          "commission": {
            "type": "object",
            "properties": {
              "id": { "type": "integer", "example": 5 },
              "title": { "type": "string", "example": "커미션 제목" }
            }
          }
        }
      },
      "ArtistItem": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 6 },
          "nickname": { "type": "string", "example": "작가닉네임" },
          "profileImageUrl": {
            "type": "string",
            "nullable": true,
            "example": "https://example.com/profile.jpg"
          }
        }
      }
    }
  }
}