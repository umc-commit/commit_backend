// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Account {
  id        BigInt   @id @default(autoincrement())
  provider  String   @db.VarChar(50)
  oauthId   String   @map("oauth_id") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")

  users   User[]
  artists Artist[]

  @@unique([provider, oauthId])
  @@map("accounts")
}

model User {
  id           BigInt   @id @default(autoincrement())
  nickname     String   @db.VarChar(50)
  accountId    BigInt   @map("account_id")
  description  String?  @db.VarChar(1000)
  profileImage String?  @map("profile_image") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  account          Account            @relation(fields: [accountId], references: [id])
  requests         Request[]
  payments         Payment[]
  points           Point[]
  pointTransaction PointTransaction[]
  chatrooms        Chatroom[]         @relation("ConsumerChatrooms")
  chatMessages     ChatMessage[]
  reviews          Review[]
  bookmarks        Bookmark[]
  follows          Follow[]
  notifications    Notification[]
  userAgreements   UserAgreement[]
  userCategories   UserCategory[]

  @@map("users")
}

model Artist {
  id           BigInt   @id @default(autoincrement())
  accountId    BigInt   @map("account_id")
  nickname     String   @db.VarChar(50)
  profileImage String?  @map("profile_image") @db.VarChar(255)
  description  String?  @db.VarChar(1000)
  slot         Int      @default(3)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  account     Account      @relation(fields: [accountId], references: [id])
  chatrooms   Chatroom[]   @relation("ArtistChatrooms")
  follows     Follow[]
  commissions Commission[]

  @@map("artists")
}

model Category {
  id   BigInt @id @default(autoincrement())
  name String @db.VarChar(100)

  commissions    Commission[]
  userCategories UserCategory[]

  @@map("categories")
}

model UserCategory {
  userId     BigInt @map("user_id")
  categoryId BigInt @map("category_id")

  user     User     @relation(fields: [userId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@id([userId, categoryId])
  @@map("user_categories")
}

model Commission {
  id         BigInt   @id @default(autoincrement())
  artistId   BigInt   @map("artist_id")
  categoryId BigInt   @map("category_id")
  title      String   @db.VarChar(200)
  summary    String   @db.VarChar(1000)
  content    String   @db.Text
  minPrice   Int      @map("min_price")
  formSchema Json?    @map("form_schema")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  artist         Artist          @relation(fields: [artistId], references: [id])
  category       Category        @relation(fields: [categoryId], references: [id])
  requests       Request[]
  bookmarks      Bookmark[]
  commissionTags CommissionTag[]

  @@map("commissions")
}

model Request {
  id           BigInt        @id @default(autoincrement())
  userId       BigInt        @map("user_id")
  commissionId BigInt        @map("commission_id")
  status       RequestStatus
  formAnswer   Json          @map("form_answer")
  waitlist     Int?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  user             User               @relation(fields: [userId], references: [id])
  commission       Commission         @relation(fields: [commissionId], references: [id])
  chatrooms        Chatroom[]
  reviews          Review[]
  PointTransaction PointTransaction[]

  @@map("requests")
}

model Payment {
  id          BigInt   @id @default(autoincrement())
  userId      BigInt   @map("user_id")
  productId   BigInt   @map("product_id")
  pgProvider  String   @map("pg_provider") @db.VarChar(100)
  price       Int
  status      String   @db.VarChar(20)
  impUid      String   @map("imp_uid") @db.VarChar(100)
  merchantUid String   @map("merchant_uid") @db.VarChar(100)
  createdAt   DateTime @default(now()) @map("created_at")

  user              User               @relation(fields: [userId], references: [id])
  product           Product            @relation(fields: [productId], references: [id])
  pointTransactions PointTransaction[]

  @@map("payments")
}

model Product {
  id    BigInt @id @default(autoincrement())
  point Int
  price Int

  payments Payment[]

  @@map("product")
}

model Point {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @unique @map("user_id")
  amount    Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("points")
}

model PointTransaction {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  paymentId BigInt?  @map("payment_id")
  requestId BigInt?  @map("request_id")
  status    String   @db.VarChar(20)
  amount    Int
  balance   Int
  createdAt DateTime @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id])
  payment Payment? @relation(fields: [paymentId], references: [id])
  request Request? @relation(fields: [requestId], references: [id])

  @@map("point_transactions")
}

model Chatroom {
  id             BigInt   @id @default(autoincrement())
  requestId      BigInt   @map("request_id")
  consumerId     BigInt   @map("consumer_id")
  artistId       BigInt   @map("artist_id")
  hiddenArtist   Boolean  @default(false) @map("hidden_artist")
  hiddenConsumer Boolean  @default(false) @map("hidden_consumer")
  createdAt      DateTime @default(now()) @map("created_at")

  request      Request       @relation(fields: [requestId], references: [id])
  consumer     User          @relation("ConsumerChatrooms", fields: [consumerId], references: [id])
  artist       Artist        @relation("ArtistChatrooms", fields: [artistId], references: [id])
  chatMessages ChatMessage[]

  @@map("chatrooms")
}

model ChatMessage {
  id         BigInt   @id @default(autoincrement())
  chatroomId BigInt   @map("chatroom_id")
  senderId   BigInt   @map("sender_id")
  content    String   @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  chatroom Chatroom @relation(fields: [chatroomId], references: [id])
  sender   User     @relation(fields: [senderId], references: [id])

  @@map("chat_messages")
}

model Follow {
  id        BigInt   @id @default(autoincrement())
  artistId  BigInt   @map("artist_id")
  userId    BigInt   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  artist Artist @relation(fields: [artistId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([userId, artistId])
  @@map("follows")
}

model Bookmark {
  id           BigInt   @id @default(autoincrement())
  userId       BigInt   @map("user_id")
  commissionId BigInt   @map("commission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  user       User       @relation(fields: [userId], references: [id])
  commission Commission @relation(fields: [commissionId], references: [id], onDelete: Cascade)

  @@unique([userId, commissionId])
  @@map("bookmarks")
}

model Tag {
  id   BigInt @id @default(autoincrement())
  name String @db.VarChar(50)

  commissionTags CommissionTag[]

  @@map("tags")
}

model CommissionTag {
  commissionId BigInt @map("commission_id")
  tagId        BigInt @map("tag_id")

  commission Commission @relation(fields: [commissionId], references: [id])
  tag        Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([commissionId, tagId])
  @@map("commission_tags")
}

model Image {
  id         BigInt @id @default(autoincrement())
  target     String @db.VarChar(50)
  targetId   BigInt @map("target_id")
  imageUrl   String @map("image_url") @db.VarChar(500)
  orderIndex Int?   @map("order_index")

  @@map("images")
}

model Notification {
  id          BigInt    @id @default(autoincrement())
  userId      BigInt    @map("user_id")
  title       String    @db.VarChar(200)
  content     String    @db.VarChar(1000)
  isRead      Boolean   @default(false) @map("is_read")
  readAt      DateTime? @map("read_at")
  type        String    @db.VarChar(50)
  relatedData Json?     @map("related_data")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model Review {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  requestId BigInt   @map("request_id")
  rate      Int
  content   String   @db.VarChar(1000)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id])
  request Request @relation(fields: [requestId], references: [id])

  @@map("reviews")
}

model Agreement {
  id        BigInt   @id @default(autoincrement())
  agreeType String   @map("agree_type") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")

  userAgreements UserAgreement[]

  @@map("agreements")
}

model UserAgreement {
  id          BigInt @id @default(autoincrement())
  userId      BigInt @map("user_id")
  agreementId BigInt @map("agreement_id")

  user      User      @relation(fields: [userId], references: [id])
  agreement Agreement @relation(fields: [agreementId], references: [id])

  @@unique([userId, agreementId])
  @@map("user_agreement")
}

model Badge {
  id   BigInt @id @default(autoincrement())
  name String @db.VarChar(100)

  @@map("badges")
}

model Session {
  id        String   @id
  sid       String   @unique
  data      String   @db.VarChar(512)
  expiresAt DateTime @map("expires_at")

  @@map("session")
}

/**
 * 커미션 신청 상태 정의
 * 플로우: 신청 > 수락 > 작업 > 작업물 전달 > 결제 > 완료
 */
enum RequestStatus {
  PENDING // 신청 후 작가 수락 대기 중
  CANCELED // 사용자가 직접 취소
  APPROVED // 작가가 수락함
  REJECTED // 작가가 거절함
  IN_PROGRESS // 작가가 작업 진행 중
  SUBMITTED // 작가가 결과물 전달함
  COMPLETED // 결제 완료 + 거래 완료 버튼 처리 -> 리뷰 작성 가능
}
